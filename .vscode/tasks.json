{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watchlight: Build",
      "type": "process",
      "command": "mise",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Watchlight: Wokwi (VS Code)",
      "type": "process",
      "command": "mise",
      "args": ["run", "simulate"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Watchlight: Check",
      "type": "process",
      "command": "mise",
      "args": ["run", "check"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Watchlight: Format",
      "type": "process",
      "command": "mise",
      "args": ["run", "lint"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Watchlight: Upload",
      "type": "process",
      "command": "mise",
      "args": ["run", "upload"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Watchlight: Monitor",
      "type": "process",
      "command": "mise",
      "args": ["run", "monitor"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
